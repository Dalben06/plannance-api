generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum EventType {
  debit
  credit
}

model User {
  id        BigInt    @id @default(autoincrement())
  uuid      String    @unique @map("uuid") @db.VarChar(64)
  email     String    @unique @db.VarChar(255)
  name      String    @db.VarChar(255)
  picture   String?   @db.VarChar(255)
  password  String    @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  @@map("users")
}

model CalendarEvent {
  id        BigInt    @id @default(autoincrement())
  userId    String    @map("user_id") @db.VarChar(64)
  title     String    @db.VarChar(255)
  startAt   DateTime  @map("start_at") @db.Timestamptz()
  endAt     DateTime? @map("end_at") @db.Timestamptz()
  amount    Decimal   @db.Decimal(12, 2)
  type      EventType
  color     String?   @db.VarChar(32)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([userId], name: "idx_calendar_events_user_id")
  @@index([startAt], name: "idx_calendar_events_start_at")
  @@map("calendar_events")
}
